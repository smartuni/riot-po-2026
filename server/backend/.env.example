# PostgreSQL Database Configuration for Docker Development
# Copy this file to .env and customize as needed

# PostgreSQL Container Configuration
POSTGRES_DB=riot_db
POSTGRES_USER=riot_user
POSTGRES_PASSWORD=riot_password
POSTGRES_PORT=5432

# Spring Boot Application Configuration
DB_USERNAME=riot_user
DB_PASSWORD=riot_password
DB_URL=jdbc:postgresql://postgres:5432/riot_db

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# MQTT Configuration (from existing setup)
MQTT_BROKER=ssl://eu1.cloud.thethings.network:8883
MQTT_CLIENT_ID=mqtt-client-1234
MQTT_USERNAME=testing-area-1@ttn
MQTT_SUBSCRIBE_TOPIC=v3/testing-area-1@ttn/devices/+/up

# JWT Configuration
JWT_SECRET=12345678901234567890123456789012

# Logging Configuration
LOGGING_LEVEL=INFO

